{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "dist",
    "rootDir": "..",
    "target": "ES2021",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2021"],
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../shared/*"]
    },
    "strict": false,
    "noImplicitAny": false
  },
  "include": ["src/**/*.ts", "../shared/**/*.ts", "../lark-bot/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
